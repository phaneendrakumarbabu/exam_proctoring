{
  "buildCommand": "pip install --upgrade pip && pip install -r requirements.txt",
  "framework": "flask",
  "python": {
    "version": "3.9"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
